# Sentinel-AML Environment Configuration Template
# Copy this file to .env and update with your actual values

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=761018880387
CDK_DEFAULT_ACCOUNT=761018880387
CDK_DEFAULT_REGION=us-east-1

# Environment
ENVIRONMENT=development
LOG_LEVEL=INFO

# Neptune Configuration
NEPTUNE_ENDPOINT=your-neptune-cluster-endpoint.cluster-xyz.neptune.amazonaws.com
NEPTUNE_PORT=8182
NEPTUNE_USE_SSL=true
NEPTUNE_MAX_CONNECTIONS=10

# Bedrock Configuration
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0
BEDROCK_MAX_TOKENS=4000

# Security Configuration
KMS_KEY_ID=your-kms-key-id
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ML Configuration
GNN_MODEL_THRESHOLD=0.7
MAX_GRAPH_NODES=50000
MODEL_INFERENCE_TIMEOUT=30

# Processing Configuration
MAX_CONCURRENT_TRANSACTIONS=1000
TRANSACTION_BATCH_SIZE=100
RETRY_MAX_ATTEMPTS=3
RETRY_BACKOFF_FACTOR=2.0

# Compliance Configuration
AUDIT_LOG_RETENTION_DAYS=2555
SAR_GENERATION_TIMEOUT=60
PII_MASKING_ENABLED=true

# API Configuration
API_RATE_LIMIT=100

# Development Configuration (for local testing)
LOCAL_NEPTUNE_ENDPOINT=localhost
LOCAL_NEPTUNE_PORT=8182