  "step_functions_timeout_minutes": 15,
  "cloudwatch_log_retention_days": 7,
  "enable_x_ray_tracing": true,
  "cost_allocation_tags": {
    "Environment": "development",
    "Project": "Sentinel-AML",
    "Owner": "dev-team",
    "CostCenter": "engineering"
  }
}